{
  "design_system": {
    "principles": [
      {
        "name": "One safe next step",
        "why": "User arrives overwhelmed",
        "visible_consequence": "Primary surface is a trail step, not metrics"
      },
      {
        "name": "Evidence in the margin",
        "why": "Trust comes from why, not count",
        "visible_consequence": "Reasons appear as side annotations"
      },
      {
        "name": "Commitment over browsing",
        "why": "Core action is choosing",
        "visible_consequence": "One commitment rail dominates"
      },
      {
        "name": "Recoverable uncertainty",
        "why": "Plans are incomplete",
        "visible_consequence": "Blocked states show repair prompts"
      }
    ],
    "tokens": {
      "colors": [
        {
          "role": "trail ink",
