          "style": "title2 rounded",
          "usage": "next action",
          "product_rationale": "human scale"
        }
      ],
      "spacing_and_shape": [
        {
          "role": "trail gap",
          "value": "20px",
          "usage": "between decisions",
          "product_rationale": "signals sequence"
        }
      ]
    },
