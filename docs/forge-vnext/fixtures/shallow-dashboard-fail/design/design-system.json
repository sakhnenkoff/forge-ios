      "Core loop centers commitment rail",
      "Empty state asks for one next evidence point"
    ],
    "empty_error_loading_rules": [
      "Empty state says: Add one signal to start the trail",
      "Error state names missing signal and repair action"
    ],
    "accessibility_rules": [
      "WCAG contrast",
      "Dynamic Type to AX3",
      "reduce motion preserves reveal order",
      "VoiceOver labels commitment state"
