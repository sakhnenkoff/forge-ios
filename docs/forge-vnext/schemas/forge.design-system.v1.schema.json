{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.local/schemas/forge.design-system.v1.schema.json",
  "title": "Forge vNext App-Specific Design System",
  "description": "Design-system contract that rejects token-only scaffold reskins and requires app-specific components, state rules, accessibility, and banned generic patterns.",
  "type": "object",
  "required": ["design_system"],
  "additionalProperties": false,
  "properties": {
    "design_system": {
      "type": "object",
      "required": [
        "principles",
        "tokens",
        "components",
        "screen_composition_rules",
        "empty_error_loading_rules",
        "accessibility_rules",
        "banned_patterns"
      ],
      "additionalProperties": false,
      "properties": {
        "principles": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "required": ["name", "why", "visible_consequence"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 2 },
              "why": { "type": "string", "minLength": 8 },
              "visible_consequence": { "type": "string", "minLength": 8 }
            }
          }
        },
        "tokens": {
          "type": "object",
          "required": ["colors", "typography", "spacing_and_shape"],
          "additionalProperties": false,
          "properties": {
            "colors": { "$ref": "#/$defs/tokenList" },
            "typography": { "$ref": "#/$defs/tokenList" },
            "spacing_and_shape": { "$ref": "#/$defs/tokenList" }
          }
        },
        "components": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "object",
            "required": ["name", "purpose", "states", "must_differ_from_scaffold_by", "usage_rules"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 3 },
              "purpose": { "type": "string", "minLength": 8 },
              "states": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "must_differ_from_scaffold_by": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 4 } },
              "usage_rules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 4 } }
            }
          }
        },
        "screen_composition_rules": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 8 } },
        "empty_error_loading_rules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 8 } },
        "accessibility_rules": { "type": "array", "minItems": 4, "items": { "type": "string", "minLength": 4 } },
        "banned_patterns": { "type": "array", "minItems": 5, "items": { "type": "string", "minLength": 4 } }
      }
    }
  },
  "$defs": {
    "tokenList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "value", "usage", "product_rationale"],
        "additionalProperties": false,
        "properties": {
          "role": { "type": "string", "minLength": 2 },
          "value": { "type": "string", "minLength": 1 },
          "usage": { "type": "string", "minLength": 4 },
          "product_rationale": { "type": "string", "minLength": 8 }
        }
      }
    }
  }
}
