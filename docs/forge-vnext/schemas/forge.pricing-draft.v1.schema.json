{
  "$id": "https://forge.local/schemas/forge.pricing-draft.v1.schema.json",
  "title": "Forge vNext pricing draft",
  "type": "object",
  "required": [
    "schemaVersion",
    "monetizationThesis",
    "recommendedModel",
    "pricePoints",
    "paywallBoundary",
    "liveSystems",
    "risks"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "monetizationThesis": {
      "type": "string",
      "minLength": 10
    },
    "recommendedModel": {
      "enum": [
        "free",
        "paid_upfront",
        "freemium",
        "subscription",
        "one_time_iap",
        "ads",
        "no_monetization_yet"
      ]
    },
    "pricePoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "tier",
          "draftPriceUSD",
          "rationale",
          "sourcePaths"
        ],
        "additionalProperties": false,
        "properties": {
          "tier": {
            "type": "string"
          },
          "draftPriceUSD": {
            "type": "number"
          },
          "rationale": {
            "type": "string"
          },
          "sourcePaths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "paywallBoundary": {
      "type": "object",
      "required": [
        "freeValue",
        "paidValue",
        "nativeEvidenceRequired"
      ],
      "additionalProperties": false,
      "properties": {
        "freeValue": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paidValue": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nativeEvidenceRequired": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "liveSystems": {
      "type": "object",
      "required": [
        "storeKitConfigured",
        "iapProductsCreated",
        "requiresHumanApprovalBeforeAnyActivation"
      ],
      "additionalProperties": false,
      "properties": {
        "storeKitConfigured": {
          "const": false
        },
        "iapProductsCreated": {
          "const": false
        },
        "requiresHumanApprovalBeforeAnyActivation": {
          "const": true
        }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false
}
